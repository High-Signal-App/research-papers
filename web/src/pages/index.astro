---
import "../styles/globals.css";
import topPapers from "../../public/data/top_papers.json";
import topCitedWorks from "../../public/data/top_cited_works.json";
import tagRating from "../../public/data/tag_rating.json";
import sleepers from "../../public/data/sleepers.json";
import hot from "../../public/data/hot.json";
import embeddingClusters from "../../public/data/embedding_clusters.json";

import { CitedWorksTable } from "@/components/tables/cited-works-table";
import { PapersTable } from "@/components/tables/papers-table";
import { TagRatingTable } from "@/components/tables/tag-rating-table";
import { SleepersTable } from "@/components/tables/sleepers-table";
import { HotTable } from "@/components/tables/hot-table";
import { SemanticSearch } from "@/components/semantic-search";
import { RagAsk } from "@/components/rag-ask";
import { EmbeddingClusters } from "@/components/embedding-clusters";
import SiteNav from "@/components/site-nav.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Search 488k research papers, inspect citation and review signals, and ask cited RAG questions over a high-citation OpenAlex Computer Science corpus." />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>researchPapers · 488k papers, semantic search, PageRank</title>
  <!-- fleet-jsonld:start (generated by apply-agent-surfaces; edit registry, not this) -->
<script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://sassmaker.com/#org","name":"SaaS Maker (Foundry)","url":"https://sassmaker.com","sameAs":["https://sassmaker.com","https://github.com/High-Signal-App/research-papers"]},{"@type":"WebSite","@id":"https://papers.highsignal.app/#app","name":"researchPapers","url":"https://papers.highsignal.app","description":"Academic paper platform over a high-citation OpenAlex CS corpus — search, analytics, and RAG demo (~488k papers).","publisher":{"@id":"https://sassmaker.com/#org"},"potentialAction":{"@type":"SearchAction","target":"https://papers.highsignal.app/?q={search_term_string}","query-input":"required name=search_term_string"}}]}</script>
<!-- fleet-jsonld:end -->
</head>
  <body class="min-h-screen antialiased font-sans">
    <SiteNav active="dashboard" />

    <main>
    <header class="max-w-7xl mx-auto px-6 pt-12 pb-6">
      <h1 class="text-4xl font-bold tracking-tight">488k papers. Search, analytics, and paid answers.</h1>
      <p class="mt-3 text-muted-foreground max-w-3xl text-base">
        Search by meaning, ask cited questions, track hot papers, and use reviewer signals to find early work worth reading.
      </p>
      <div class="mt-5">
        <a href="#search" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-primary-foreground font-semibold text-sm hover:opacity-90 transition-opacity">
          Search 488k abstracts &rarr;
        </a>
      </div>
    </header>

    <section id="search" class="max-w-7xl mx-auto px-6 pb-8">
      <div class="rounded-2xl border bg-card p-6 md:p-8 space-y-4">
        <div>
          <h2 class="text-xs uppercase tracking-wider text-muted-foreground font-semibold">Semantic search</h2>
          <p class="text-sm text-muted-foreground mt-1">
            Natural-language search across 488k abstracts. Powered by all-MiniLM-L6-v2 embeddings + cosine similarity over ClickHouse.
            Try: <span class="font-mono text-foreground/70">"papers about emergent capabilities"</span> or <span class="font-mono text-foreground/70">"diffusion model training instability"</span>.
          </p>
        </div>
        <SemanticSearch client:load />
      </div>
    </section>

    <section id="rag" class="max-w-7xl mx-auto px-6 pb-8">
      <div class="rounded-2xl border bg-card p-6 md:p-8 space-y-4">
        <div>
          <h2 class="text-xs uppercase tracking-wider text-muted-foreground font-semibold">Research answer API</h2>
          <p class="text-sm text-muted-foreground mt-1">
            A demo of the monetizable data-app layer: users ask a high-value question, the backend calls a live Knowledgebase RAG domain,
            and the response returns cited evidence from high-citation OpenAlex Computer Science papers.
          </p>
        </div>
        <RagAsk client:load />
      </div>
    </section>

    {hot?.length > 0 && (
      <section id="hot" class="max-w-7xl mx-auto px-6 py-8 space-y-3">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold tracking-tight">Hot right now</h2>
          <p class="text-sm text-muted-foreground">
            Recent papers combining citation velocity, peer-review signal where available, and graph centrality.
          </p>
        </div>
        <HotTable client:visible data={hot} />
      </section>
    )}

    {sleepers?.length > 0 && (
      <section id="sleepers" class="max-w-7xl mx-auto px-6 py-8 space-y-3">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold tracking-tight">Reviewer-loved early work</h2>
          <p class="text-sm text-muted-foreground">
            High OpenReview scores on recent submissions. Citation counts for OpenReview-only records are hidden until a verified citation crosswalk is added.
          </p>
        </div>
        <SleepersTable client:visible data={sleepers} />
      </section>
    )}

    {tagRating?.length > 0 && (
      <section id="tag-rating" class="max-w-7xl mx-auto px-6 py-8 space-y-3">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold tracking-tight">Topics reviewers are most excited about</h2>
          <p class="text-sm text-muted-foreground">
            Mean reviewer rating by extracted topic. This is the compact view of what top venues are rewarding.
          </p>
        </div>
        <TagRatingTable client:visible data={tagRating} />
      </section>
    )}

    {embeddingClusters?.length > 0 && (
      <section id="clusters" class="max-w-7xl mx-auto px-6 py-8 space-y-3">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold tracking-tight">Research map</h2>
          <p class="text-sm text-muted-foreground">
            Semantic clusters from MiniLM embeddings. Use this as the one map of the corpus, not a separate diagnostics area.
          </p>
        </div>
        <EmbeddingClusters client:visible data={embeddingClusters} />
      </section>
    )}

    <section id="top-papers" class="max-w-7xl mx-auto px-6 py-8 space-y-3">
      <div class="space-y-1">
        <h2 class="text-2xl font-semibold tracking-tight">Top papers</h2>
        <p class="text-sm text-muted-foreground">The strongest papers in the corpus by citations and graph centrality.</p>
      </div>
      <PapersTable client:visible data={topPapers} />
    </section>

    <section id="cited-works" class="max-w-7xl mx-auto px-6 py-8 space-y-3">
      <div class="space-y-1">
        <h2 class="text-2xl font-semibold tracking-tight">What the field cites</h2>
        <p class="text-sm text-muted-foreground">Works most cited by the corpus, useful as a compact reading list of durable foundations.</p>
      </div>
      <CitedWorksTable client:visible data={topCitedWorks} />
    </section>
    </main>

    <footer class="max-w-7xl mx-auto px-6 py-12 text-center text-xs text-muted-foreground border-t mt-12">
      <p class="text-sm font-medium text-foreground/70 mb-1">488,491 papers ingested. 1.05M edges computed. 64 clusters mapped.</p>
      <p>arxiv · OpenReview · bioRxiv · medRxiv · ClickHouse · semantic search via all-MiniLM-L6-v2 · tables via TanStack + shadcn</p>
    </footer>

    <script src="/api-config.js" is:inline></script>

    <!-- PostHog + API timing -->
    <script>
      import { installBrowserMonitoring } from '@/lib/foundry-monitoring';
      import { initApiTiming } from '@/lib/api-timing';
      installBrowserMonitoring();
      initApiTiming();
    </script>
  </body>
</html>
