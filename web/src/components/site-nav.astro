---
type ActivePage = "dashboard" | "digest" | "paths" | "data";

type Props = {
  active: ActivePage;
};

const { active } = Astro.props;

const linkClass = (page: ActivePage) =>
  [
    "inline-flex h-9 items-center rounded-md px-3 text-sm font-medium transition-colors",
    active === page
      ? "bg-primary/15 text-primary"
      : "text-muted-foreground hover:bg-muted/60 hover:text-foreground",
  ].join(" ");

const dropdownSummary =
  "inline-flex h-9 cursor-pointer list-none items-center gap-1 rounded-md px-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted/60 hover:text-foreground [&::-webkit-details-marker]:hidden";

const dropdownPanel =
  "absolute left-0 top-10 z-50 min-w-56 max-w-[calc(100vw-3rem)] rounded-lg border bg-popover p-2 text-sm shadow-xl sm:left-auto sm:right-0";

const dropdownLink =
  "block rounded-md px-3 py-2 text-muted-foreground transition-colors hover:bg-muted/60 hover:text-foreground";
---

<nav class="sticky top-0 z-40 border-b bg-background/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl flex-col items-start gap-2 px-6 py-3 sm:flex-row sm:items-center sm:gap-4">
    <a href="/" class="shrink-0 text-sm font-semibold tracking-tight text-foreground/90 hover:text-primary">
      researchPapers
    </a>
    <ul class="flex w-full flex-wrap items-center gap-1 sm:min-w-0 sm:flex-1">
      <li>
        <a href="/" class={linkClass("dashboard")}>Dashboard</a>
      </li>
      <li>
        <a href="/digest" class={linkClass("digest")}>Digest</a>
      </li>
      <li>
        <a href="/paths" class={linkClass("paths")}>Reading paths</a>
      </li>
      <li>
        <a href="/data" class={linkClass("data")}>Data</a>
      </li>
      <li class="relative sm:ml-auto">
        <details class="group">
          <summary class={dropdownSummary}>
            Research
            <span class="text-[10px] transition-transform group-open:rotate-180">v</span>
          </summary>
          <div class={dropdownPanel}>
            <a href="/#search" class={dropdownLink}>Semantic search</a>
            <a href="/#rag" class={dropdownLink}>Research answer API</a>
            <a href="/#hot" class={dropdownLink}>Hot papers</a>
            <a href="/#sleepers" class={dropdownLink}>Sleeper papers</a>
            <a href="/#tag-rating" class={dropdownLink}>Reviewer topics</a>
            <a href="/#clusters" class={dropdownLink}>Research map</a>
            <a href="/#cited-works" class={dropdownLink}>Cited works</a>
          </div>
        </details>
      </li>
      <li class="relative">
        <details class="group">
          <summary class={dropdownSummary}>
            Browse
            <span class="text-[10px] transition-transform group-open:rotate-180">v</span>
          </summary>
          <div class={dropdownPanel}>
            <a href="/paths#sutskever-carmack-core" class={dropdownLink}>Sutskever/Carmack core</a>
            <a href="/paths#karpathy-llm-systems" class={dropdownLink}>Karpathy LLM systems</a>
            <a href="/paths#lecun-world-models" class={dropdownLink}>LeCun world models</a>
            <a href="/paths#human-compatible-ai-safety" class={dropdownLink}>Human-compatible safety</a>
            <a href="/digest" class={dropdownLink}>Daily digest</a>
          </div>
        </details>
      </li>
    </ul>
  </div>
</nav>
